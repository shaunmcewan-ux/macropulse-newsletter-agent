# Copy this file to .env and fill in your values

# Mailchimp — get your API key from:
# Mailchimp → Account → Extras → API keys → Create A Key
MAILCHIMP_API_KEY=your-api-key-here-us1

# Mailchimp audience/list ID — get from:
# Mailchimp → Audience → Manage Audience → Settings → Audience name and defaults
MAILCHIMP_LIST_ID=your-list-id-here

# Sender details
MAILCHIMP_FROM_NAME=MacroPulse
MAILCHIMP_FROM_EMAIL=shaunmcewan@gmail.com

# Where test emails go for approval review
MAILCHIMP_TEST_EMAIL=shaunmcewan@gmail.com
