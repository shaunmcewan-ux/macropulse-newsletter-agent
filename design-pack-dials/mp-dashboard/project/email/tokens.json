{
  "$schema": "https://design-tokens.org/schema",
  "meta": {
    "name": "MacroPulse Email Tokens",
    "version": "1.0.0",
    "context": "html-email",
    "notes": "Email-client safe palette. Arial/Helvetica system stack. Dark mode default."
  },
  "color": {
    "bg": {
      "page":       { "value": "#0a0a0a", "description": "Email body background" },
      "card":       { "value": "rgba(255,255,255,0.05)", "description": "Card fill (modern clients)" },
      "cardSolid":  { "value": "#141414", "description": "Card fill (Outlook fallback)" },
      "inverted":   { "value": "#ffffff", "description": "Inverted block (e.g. allocation total)" }
    },
    "border": {
      "soft":       { "value": "rgba(255,255,255,0.10)" },
      "softSolid":  { "value": "#222222", "description": "Outlook fallback equivalent on #0a0a0a" },
      "hair":       { "value": "rgba(255,255,255,0.06)" }
    },
    "text": {
      "primary":   { "value": "#ffffff" },
      "secondary": { "value": "rgba(255,255,255,0.68)", "fallback": "#adadad" },
      "muted":     { "value": "rgba(255,255,255,0.45)", "fallback": "#737373" },
      "onLight":   { "value": "#0a0a0a", "description": "Text on inverted block" }
    },
    "accent": {
      "orange": { "value": "#f97316" },
      "blue":   { "value": "#3b82f6" },
      "green":  { "value": "#22c55e" },
      "red":    { "value": "#dc2626" },
      "yellow": { "value": "#eab308" },
      "purple": { "value": "#a855f7" }
    },
    "pill": {
      "positiveBg":   { "value": "rgba(34,197,94,0.15)",  "fallback": "#0f2a1a" },
      "positiveText": { "value": "#4ade80" },
      "negativeBg":   { "value": "rgba(220,38,38,0.15)",  "fallback": "#2a1010" },
      "negativeText": { "value": "#f87171" },
      "neutralBg":    { "value": "rgba(255,255,255,0.08)", "fallback": "#1a1a1a" },
      "neutralText":  { "value": "rgba(255,255,255,0.68)" }
    },
    "chip": {
      "fomc":        { "bg": "rgba(168,85,247,0.18)", "text": "#c4a8f5" },
      "cpi":         { "bg": "rgba(59,130,246,0.18)", "text": "#93b8f7" },
      "nfp":         { "bg": "rgba(249,115,22,0.18)", "text": "#f9b27a" },
      "earnings":    { "bg": "rgba(34,197,94,0.18)",  "text": "#7bd4a0" },
      "geopolitics": { "bg": "rgba(220,38,38,0.18)",  "text": "#f08c8c" }
    },
    "gradient": {
      "pulse": {
        "value": "linear-gradient(90deg,#dc2626 0%,#f97316 24%,#eab308 48%,#22c55e 76%,#a855f7 100%)",
        "stops": [
          { "at": "0%",   "color": "#dc2626", "label": "Sell" },
          { "at": "24%",  "color": "#f97316", "label": "Hold" },
          { "at": "48%",  "color": "#eab308", "label": "Buy BTC" },
          { "at": "76%",  "color": "#22c55e", "label": "Alt Season" },
          { "at": "100%", "color": "#a855f7", "label": "Top" }
        ]
      }
    }
  },
  "type": {
    "stack": "Arial, Helvetica, 'Helvetica Neue', sans-serif",
    "stackMono": "'SF Mono', Consolas, Menlo, monospace",
    "scale": {
      "eyebrow":  { "size": "11px", "weight": 600, "tracking": "0.28em", "case": "uppercase", "color": "text.muted" },
      "label":    { "size": "12px", "weight": 600, "tracking": "0.2em",  "case": "uppercase" },
      "metric":   { "size": "13px", "weight": 700 },
      "body":     { "size": "16px", "weight": 400, "leading": "1.7",  "color": "text.secondary" },
      "lede":     { "size": "18px", "weight": 400, "leading": "1.55", "color": "text.primary" },
      "h3":       { "size": "20px", "weight": 600, "leading": "1.3",  "tracking": "-0.01em" },
      "h2":       { "size": "26px", "weight": 600, "leading": "1.2",  "tracking": "-0.015em" },
      "h1":       { "size": "32px", "weight": 700, "leading": "1.15", "tracking": "-0.02em" },
      "display":  { "size": "40px", "weight": 700, "leading": "1.1",  "tracking": "-0.02em" },
      "tileValue":{ "size": "28px", "weight": 600 }
    }
  },
  "spacing": {
    "container": "600px",
    "gutter":    "32px",
    "cardPadding":     "32px",
    "cardPaddingSm":   "24px",
    "blockSpacing":    "20px",
    "sectionSpacing":  "32px"
  },
  "radius": {
    "card": "32px",
    "tile": "20px",
    "pill": "999px",
    "chip": "999px",
    "rule": "1px"
  },
  "components": {
    "header":        { "padding": "32px 32px 24px" },
    "pulseStrip":    { "svgWidth": 560, "svgHeight": 56, "pointerWidth": 4, "pointerColor": "#ffffff" },
    "chartSpotlight":{ "svgWidth": 560, "svgHeight": 210 },
    "calendarChip":  { "padding": "6px 12px", "radius": "999px" },
    "marketTable":   { "rowHeight": 52, "pillSize": "12px/600" }
  }
}
